@startuml
skinparam state {
  BackgroundColor #ffffff
  BorderColor #2563EB
  ArrowColor #333333
}

[*] --> INITIALISING : Instantiate / AudioVisualizer(target_function)

state INITIALISING {
  [*] --> PreparingData

  PreparingData : entry / _prepare_data()
  note right of PreparingData : Samples x values\nRuns _evaluate_target_function()\nBuilds vertical line mode if needed\nCleans NaNs and asymptotes\nCreates safe fallback if no valid points remain

  PreparingData --> ValidationError : invalid shape, invalid vertical line, or other unexpected evaluation error
  PreparingData --> GeneratingAudio : valid data or safe fallback
  
  GeneratingAudio : entry / _generate_audio_sequence()
  note right of GeneratingAudio : Normalizes y into frequencies\nGenerates one smooth centered stereo signal\nCan produce empty or fallback-safe audio
  
  GeneratingAudio --> SettingUpPlot
  
  SettingUpPlot : entry / _setup_plot()
  note right of SettingUpPlot : Configures matplotlib UI\nShows fallback message if no valid graph points exist\nBinds close_event
  
  SettingUpPlot --> [*]

  state ValidationError
  ValidationError : entry / raise ValueError
  ValidationError --> [*]
}


' INITIALISING -right-> READY
INITIALISING --> READY


' READY -right-> ANIMATING : play() / Start FuncAnimation
READY --> ANIMATING : play() / Start FuncAnimation

state ANIMATING {
  [*] --> PendingFirstFrame

  PendingFirstFrame --> NoPlotData : update [has_plot_data == False] / return without audio or point movement
  PendingFirstFrame --> PlaybackAndSync : update [audio_started == False] / sd.play(), record start_time, audio_started = True
  
  PlaybackAndSync --> PlaybackAndSync : update [current_index < len(x_clean)] / calculate elapsed time, update point
  
  PlaybackAndSync --> SequenceComplete : update [current_index >= len(x_clean)] / clamp to last index

  NoPlotData --> NoPlotData : update / keep fallback message visible
  SequenceComplete --> SequenceComplete : update / hold point position
}


ANIMATING --> [*] : close_event / sd.stop()


READY --> [*] : close_event / sd.stop()

@enduml
