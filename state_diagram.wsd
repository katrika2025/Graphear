@startuml
skinparam state {
  BackgroundColor #F8F9FA
  BorderColor #2563EB
  ArrowColor #333333
}

[*] --> INITIALIZING : Instantiate / AudioVisualizer(target_function)

state INITIALIZING {
  [*] --> EvaluatingData
  
  EvaluatingData : entry / _evaluate_target_function(), _validate_y_values()
  
  EvaluatingData --> CleaningData : [Evaluation successful]
  EvaluatingData --> ErrorFallback : [Exception OR Validation failed]
  
  CleaningData : entry / Filter NaNs and asymptotes
  
  CleaningData --> GeneratingAudio : [x_clean.size > 0]
  CleaningData --> ErrorFallback : [x_clean.size == 0]
  
  ErrorFallback : entry / _use_no_plot_fallback()
  note right of ErrorFallback : Safely catches errors,\nsets has_plot_data = False,\nprovides safe dummy data
  
  ErrorFallback --> GeneratingAudio : [Fallback applied]
  
  GeneratingAudio : entry / _generate_audio_sequence()
  note right of GeneratingAudio : Normalizes frequencies,\nsynthesizes stereo audio
  
  GeneratingAudio --> SettingUpPlot : [Audio sequence generated]
  
  SettingUpPlot : entry / _setup_plot()
  note right of SettingUpPlot : Configures matplotlib UI,\nbinds close_event
  
  SettingUpPlot --> [*]
}

INITIALIZING --> READY : [Initialization complete]

READY --> ANIMATING : play() / Start FuncAnimation

state ANIMATING {
  [*] --> EvaluatingDataState
  
  EvaluatingDataState --> NoDataIdle : [has_plot_data == False]
  EvaluatingDataState --> PendingFirstFrame : [has_plot_data == True]
  
  NoDataIdle --> NoDataIdle : update / return empty point
  
  PendingFirstFrame --> PlaybackAndSync : update [audio_started == False] / sd.play(), record latency & time, audio_started = True
  
  PlaybackAndSync --> PlaybackAndSync : update [current_index < len(x_clean)] / calculate elapsed time, update point position
  
  PlaybackAndSync --> SequenceComplete : update [current_index >= len(x_clean)] / clamp index, update point position
  
  SequenceComplete --> SequenceComplete : update / hold point position
}

ANIMATING --> [*] : close_event / sd.stop(), Terminate Process
READY --> [*] : close_event / sd.stop(), Terminate Process

@enduml